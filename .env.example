# Copy to .env.local and fill in from Supabase → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Set to true to use the local sample map without logging in (optional)
# VITE_DEV_SKIP_AUTH=true

# Google sign-in (required for cloud auth):
# 1. Supabase → Authentication → Providers → Google → Enable
# 2. Google Cloud Console → OAuth client → add Supabase redirect URI from the provider page
# 3. Supabase → Authentication → URL configuration → add http://localhost:5173 (and production URL)
